# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.venv/
venv/
.env
.env.*

# Model checkpoints (keep logs/figures/configs; pull weights from HPC or HF)
runs/**/checkpoints/*.pt
*.pth

# Data (HPC symlink, too large for git)
data
data/

# Slurm job outputs (noisy; keep one reference out_sample if useful)
runs/*_*.out
runs/*_*.err

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Claude local settings (do not publish)
.claude/
CLAUDE.md

# Coursework artifacts: kept locally as a personal record but not part of
# the public release. Includes assignment.pdf, the CS-137 final-report
# tex/submission/figures/slides, the Tufts evaluator wrappers, and the
# Tufts HPC SLURM batch files. Internal notes (progress.md, audit logs)
# also live here.
CS137-assignment/

# docs/ holds only the public-facing arXiv paper PDF; everything else is
# private working drafts kept locally.
docs/*
!docs/paper.pdf

# report/ holds only the public arXiv source tree; legacy course-flavored
# subfolders have been moved to CS137-assignment/report/.
report/*
!report/arxiv/
!report/arxiv/**

# LaTeX intermediates inside report/arxiv/ — built artifact (paper.pdf) IS
# tracked, but the build cruft is not.
report/arxiv/paper.aux
report/arxiv/paper.bbl
report/arxiv/paper.blg
report/arxiv/paper.fdb_latexmk
report/arxiv/paper.fls
report/arxiv/paper.log
report/arxiv/paper.out
report/arxiv/paper.xdv

# Generic data/ rule (line 16-17 above) excludes the arXiv-specific JSON;
# force-add via exception.
!report/arxiv/data/
!report/arxiv/data/**

# Recovery-only scratch files (session-specific)
hpc相关信息供参考.txt
part1提交.txt
