# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.venv/
venv/
.env
.env.*

# Model checkpoints (keep logs/figures/configs; pull weights from HPC or HF)
runs/**/checkpoints/*.pt
*.pth

# Data (HPC symlink, too large for git)
data
data/

# Slurm job outputs (noisy; keep one reference out_sample if useful)
runs/*_*.out
runs/*_*.err

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Claude local settings (do not publish)
.claude/
CLAUDE.md

# Working drafts and Claude collaboration artifacts (kept locally, not synced)
docs/
# Report subfolders are local-only — final CS-137 deliverables are uploaded
# directly to GradeScope from report/submission/, not synced through GitHub.
# The arXiv subtree (report/arxiv/) is intentionally public, so we exclude
# the *other* subfolders explicitly rather than the whole parent.
report/tex/
report/submission/
report/figures/
report/slides/
report/project-report-这个之后弄/
report/AUDIT_*.md
report/README.md

# LaTeX intermediates inside report/arxiv/ — built artifact (paper.pdf) IS
# tracked, but the build cruft is not.
report/arxiv/paper.aux
report/arxiv/paper.bbl
report/arxiv/paper.blg
report/arxiv/paper.fdb_latexmk
report/arxiv/paper.fls
report/arxiv/paper.log
report/arxiv/paper.out
report/arxiv/paper.xdv

# Generic data/ rule excludes the arXiv-specific JSON; force-add via exception.
!report/arxiv/data/
!report/arxiv/data/**

# Course material — don't redistribute (assignment.pdf, etc.)
**/assignment.pdf

# Recovery-only scratch files (session-specific)
hpc相关信息供参考.txt
part1提交.txt
